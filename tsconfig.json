{
    "compilerOptions": {
        "rootDir": "src",
        "outDir": "dist",
        "module": "Node16",
        "moduleResolution": "Node16",
        "target": "ES2023",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "sourceMap": true,
        "strict": true
    },
    "include": [
        "src",
        "types"
    ],
    "exclude": [
        "prisma.config.ts",
        "node_modules"
    ]
}
